import psutil
import wmi
import time
import json
import datetime

# -------- CONFIG -------- #
SUSPICIOUS_PAIRS = {
    ("winword.exe", "powershell.exe"),
    ("excel.exe", "cmd.exe"),
    ("outlook.exe", "powershell.exe"),
    ("explorer.exe", "powershell.exe")
}

WHITELIST = {
    "explorer.exe", "chrome.exe", "python.exe",
    "svchost.exe", "services.exe", "lsass.exe",
    "code.exe", "openconsole.exe"
}

# Trusted apps that can run from temp/appdata without triggering alerts
TRUSTED_TEMP_APPS = {
    "chrome.exe", "firefox.exe", "python.exe", "pip.exe",
    "code.exe", "node.exe", "git.exe", "msiexec.exe"
}

LOG_FILE = "alerts.json"

# -------- RISK SCORING -------- #
def calculate_risk(alert_type):
    if alert_type == "parent_child":
        return "HIGH"
    elif alert_type == "service":
        return "MEDIUM"
    elif alert_type == "process":
        return "LOW"
    return "UNKNOWN"

# -------- JSON LOGGING -------- #
def log_json(alert):
    try:
        with open(LOG_FILE, "r") as f:
            data = json.load(f)
    except:
        data = []

    data.append(alert)

    with open(LOG_FILE, "w") as f:
        json.dump(data, f, indent=4)

# -------- PROCESS COLLECTION -------- #
def get_processes():
    processes = {}
    for p in psutil.process_iter(['pid', 'ppid', 'name', 'exe']):
        try:
            processes[p.info['pid']] = p.info
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            continue
    return processes

# -------- DETECTION: PARENT-CHILD -------- #
def detect_parent_child(processes):
    alerts = []

    for pid, info in processes.items():
        parent = processes.get(info['ppid'])

        if parent:
            pair = (parent['name'].lower(), info['name'].lower())

            if pair in SUSPICIOUS_PAIRS:
                alerts.append({
                    "type": "parent_child",
                    "message": f"{parent['name']} -> {info['name']}",
                    "risk": calculate_risk("parent_child")
                })

    return alerts

# -------- DETECTION: UNKNOWN PROCESS -------- #
def detect_suspicious_process(processes):
    alerts = []

    for pid, info in processes.items():
        name = info['name']
        path = info.get('exe')
        name_lower = name.lower() if name else ""

        # Skip whitelisted processes
        if name_lower in {w.lower() for w in WHITELIST}:
            continue

        # Check if running from suspicious paths
        if path and ("temp" in path.lower() or "appdata" in path.lower()):
            # Allow trusted apps to run from temp/appdata
            if name_lower in {w.lower() for w in TRUSTED_TEMP_APPS}:
                continue

            # Only flag if also an unknown process
            alerts.append({
                "type": "process",
                "message": f"{name} from {path}",
                "risk": calculate_risk("process")
            })

    return alerts

# -------- DETECTION: SERVICES -------- #
def detect_services():
    alerts = []
    c = wmi.WMI()

    for service in c.Win32_Service():
        path = str(service.PathName)

        if "temp" in path.lower() or "appdata" in path.lower():
            alerts.append({
                "type": "service",
                "message": f"{service.Name} -> {path}",
                "risk": calculate_risk("service")
            })

    return alerts

# -------- DASHBOARD -------- #
def print_dashboard(alerts):
    print("\n===== SECURITY DASHBOARD =====")

    if not alerts:
        print("No suspicious activity detected.")

    for alert in alerts:
        print(f"[{alert['risk']}] {alert['type']} -> {alert['message']}")

# -------- MAIN MONITOR FUNCTION -------- #
def monitor():
    print("Advanced Monitoring Started...\n")

    while True:
        processes = get_processes()

        alerts = []
        alerts += detect_parent_child(processes)
        alerts += detect_suspicious_process(processes)
        alerts += detect_services()

        timestamp = str(datetime.datetime.now())

        for alert in alerts:
            alert["timestamp"] = timestamp
            log_json(alert)

        print_dashboard(alerts)

        time.sleep(5)

# -------- ENTRY POINT -------- #
def main():
    monitor()

if __name__ == "__main__":
    main()
